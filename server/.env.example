# Copie ce fichier en « .env » et remplis les vraies valeurs.
# .env est ignore par git : les vraies valeurs ne doivent JAMAIS y arriver.

# ————— La base —————
# Railway : service Postgres → onglet Variables → DATABASE_URL
DATABASE_URL=postgresql://utilisateur:motdepasse@hote:5432/railway

# ————— Le secret qui signe les sessions —————
# Sans lui, n'importe qui peut fabriquer un jeton et se faire passer
# pour un autre joueur. En genere un avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ————— Les origines autorisees (separees par des virgules) —————
# L'adresse Vercel du jeu. localhost:5173 est deja autorise d'office.
#
# ⚠️ EXACTEMENT l'adresse, SANS barre oblique finale. Le serveur compare cette
# chaine caractere par caractere a l'en-tete `Origin` du navigateur, et un
# navigateur n'envoie JAMAIS de « / » a la fin. Avec « .app/ », la comparaison
# echoue et le navigateur bloque tout : connexion, boutique, classement — sans
# message d'erreur qui dise pourquoi.
ORIGINES_AUTORISEES=https://kurogane-alpha.vercel.app

# ————— Se connecter avec Google (facultatif) —————
# Sans ces deux cles, le bouton Google reste masque et tout le reste marche.
# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID
# (type « Web application »).
#
# ⚠️ URI de redirection autorisee A ENREGISTRER, exactement :
#   local : http://localhost:2567/api/auth/callback/google
#   prod  : https://kurogane-production.up.railway.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# L'adresse PUBLIQUE du serveur — Better Auth s'en sert pour construire l'URI
# de redirection.
#
# ⚠️ EN LOCAL, LAISSER VIDE. Y mettre l'adresse de production ferait croire au
# serveur qu'il tourne sur Railway : il refuserait le relais de retour (qui
# pointe sur localhost) et enverrait Google rediriger vers la production.
# Symptome : le bouton Google ne fait rien.
# A remplir UNIQUEMENT dans les variables Railway.
PUBLIC_URL=
