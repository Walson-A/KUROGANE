# Copie ce fichier en « .env » et remplis les vraies valeurs.
# .env est ignore par git : les vraies valeurs ne doivent JAMAIS y arriver.

# ————— La base —————
# Railway : service Postgres → onglet Variables → DATABASE_URL
DATABASE_URL=postgresql://utilisateur:motdepasse@hote:5432/railway

# ————— Le secret qui signe les sessions —————
# Sans lui, n'importe qui peut fabriquer un jeton et se faire passer
# pour un autre joueur. En genere un avec :
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=

# ————— Les origines autorisees (separees par des virgules) —————
# L'adresse Vercel du jeu. localhost:5173 est deja autorise d'office.
ORIGINES_AUTORISEES=https://kurogane.vercel.app
